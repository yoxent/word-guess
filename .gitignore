# ── Expo / React Native ──────────────────────────────────────
node_modules/
.expo/
dist/
web-build/

# Generated native projects (regenerated via npx expo prebuild)
android/
ios/

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── EAS Build ────────────────────────────────────────────────
*.apk
*.aab
eas-build-node-*.tgz

# ── Environment & Secrets (never commit) ────────────────────
.env
.env.local
.env.production
.env.development
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ── Dictionary source + generated files (regenerated via postinstall) ─
dictionary.full.enriched.json
assets/dictionary/*.json

# ── Agent artifacts (pi-subagents session data) ──────────────
.pi-subagents/

# ── Machine-specific agent config (regenerated on clone) ────
.claude/

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Maestro E2E ────────────────────────────────────────────
.maestro/
maestro/
maestro/artifacts/
maestro/reports/
maestro/flows/.generated/

# ── Dev scripts (not needed in release builds) ──────────────
scripts/

# ── Temp / junk files ───────────────────────────────────────
nul
*.log
*.tmp
*.temp
google-services.json
